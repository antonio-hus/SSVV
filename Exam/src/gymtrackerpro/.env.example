#
# DATABASE CONNECTION STRING
#
# Connection URL for your PostgreSQL database.
# Format: postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>
# Example: postgresql://postgres:postgres@localhost:5432/gymtrackerpro
#
DATABASE_URL="postgresql://<user>:<password>@<host>:<port>/<database>"
#
# SESSION CONFIGURATION
#
# Secret key used by Iron Session to encrypt and sign session cookies.
# Must be at least 32 characters long and randomly generated.
#
# You can generate a secure secret using Node.js:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Or using OpenSSL:
#   openssl rand -hex 32
#
IRON_SESSION_SECRET="<your-random-32+ character-secret-here>"