#
# Local development database
#
# Used by `npm run dev` and Prisma CLI when running outside Docker.
# When using docker-compose, the DATABASE_URL is constructed internally
# from POSTGRES_PASSWORD and the `db` service hostname - this value is ignored.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gymtrackerpro"
#
# Used by docker-compose to configure the postgres container and to build the
# DATABASE_URL passed into the migrate and app containers.
# Must match the password in DATABASE_URL above when developing locally.
POSTGRES_PASSWORD=postgres
#
# Session secret
#
# Used by iron-session to sign and encrypt session cookies.
# Required - compose will refuse to start the app container without it.
# Generate a new one with: openssl rand -base64 32
IRON_SESSION_SECRET=
#
# Seed admins
#
# JSON array of admin accounts to create when the database is first populated.
# The seed runs as part of `docker compose up` via the migrate service.
# Already-existing emails are silently skipped, so re-running is safe.
# If left empty, one default admin is created: admin@gymtrackerpro.com / admin
#
# Format:
# SEED_ADMINS='[{"email":"...","password":"...","name":"...","phone":"...","dob":"YYYY-MM-DD"}]'
#
# Example with two admins:
# SEED_ADMINS='[{"email":"alice@gym.com","password":"password","name":"Alice","phone":"+1111111111","dob":"1985-03-15"},{"email":"bob@gym.com","password":"password","name":"Bob","phone":"+2222222222","dob":"1990-07-22"}]'
SEED_ADMINS=[{"email":"admin@gymtrackerpro.com","password":"admin","name":"GymAdministrator","phone":"+40773758938","dob":"2005-05-04"}]
#
# App port
#
# Host port that the Next.js container is mapped to.
# Change this if port 3000 is already in use on your machine.
APP_PORT=3000
