{
  "name": "gymtrackerpro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --testPathPatterns='^(?!.*integration).*$'",
    "test:watch": "jest --watch --testPathPatterns='^(?!.*integration).*$'",
    "test:coverage": "jest --coverage --testPathPatterns='^(?!.*integration).*$'",
    "test:integration": "npm run test:integration:up && dotenv -e .env.test -- npx prisma migrate deploy && jest --testPathPatterns=integration -i",
    "test:integration:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:integration:down": "docker compose -f docker-compose.test.yml down -v"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts",
    "seed-demo-data": "npx tsx prisma/seed-demo-data.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@viz-js/viz": "^3.26.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "exceljs": "^4.4.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
